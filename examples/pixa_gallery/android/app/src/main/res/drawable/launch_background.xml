<?xml version="1.0" encoding="utf-8"?>
<!-- Pixa branded launch splash: neumorphic base colour with a centered bolt mark. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/pixa_brand_base" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/pixa_splash"
            android:tint="@color/pixa_brand_accent" />
    </item>
</layer-list>
